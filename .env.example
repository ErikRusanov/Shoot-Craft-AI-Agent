# Copy to .env for local dev. Field names map case-insensitively (see src/config.py).

# --- App / server ---
APP_ENV=dev
HOST=0.0.0.0
PORT=8000
RELOAD=false

# --- Logging ---
LOG_LEVEL=INFO
LOG_JSON=false

# --- Redis (state store + event bus) ---
REDIS_URL=redis://localhost:6379/0
FACE_TTL_SECONDS=3600
SESSION_TTL_SECONDS=86400
EVENT_STREAM_MAXLEN=1000

# --- Generation (Nano Banana 2 via OpenRouter) ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
GENERATION_MODEL=google/gemini-3.1-flash-image-preview
OPENROUTER_TIMEOUT_SECONDS=120

# --- Face check (CV) ---
INSIGHTFACE_MODEL=buffalo_l
FACE_MATCH_THRESHOLD=0.35

# --- Object storage ---
OBJECT_STORAGE=local
LOCAL_STORAGE_PATH=./.storage
# S3_ENDPOINT_URL=
# S3_REGION=
# S3_BUCKET=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# --- Presets: package | path | examples ---
PRESET_SOURCE=examples
# PRESET_LIBRARY_PATH=../presets

# --- Generation loop ---
MAX_ITERATIONS=8
