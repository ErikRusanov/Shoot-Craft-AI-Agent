# Copy to .env for local dev. Field names map case-insensitively (see src/config.py).

# --- App / server ---
APP_ENV=dev
HOST=0.0.0.0
PORT=8000
RELOAD=false

# --- Logging ---
LOG_LEVEL=INFO
LOG_JSON=false

# --- Redis (state store + event bus) ---
# Set -> Redis connectors; unset -> in-memory (decided once at process start).
# `make infra` starts a local Redis on this URL.
REDIS_URL=redis://localhost:6379/0
FACE_TTL_SECONDS=3600
SESSION_TTL_SECONDS=86400
EVENT_STREAM_MAXLEN=1000

# --- Generation (Nano Banana 2 via OpenRouter) ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
GENERATION_MODEL=google/gemini-3.1-flash-image-preview
OPENROUTER_TIMEOUT_SECONDS=120

# --- Face check (CV) ---
INSIGHTFACE_MODEL=buffalo_l
# Weights dir; `make models` downloads the pack here (never committed).
INSIGHTFACE_ROOT=./.models
INSIGHTFACE_DET_SIZE=640
FACE_MATCH_THRESHOLD=0.35

# --- Input-photo quality gate (thresholds on FrameMetrics) ---
GATE_MIN_SIDE=512
GATE_MIN_FACE_SIDE=128.0
GATE_MAX_SECONDARY_FACE_RATIO=0.25
GATE_MIN_BLUR_VAR=60.0
GATE_MIN_BRIGHTNESS=50.0
GATE_MAX_BRIGHTNESS=230.0

# --- Object storage ---
OBJECT_STORAGE=local
LOCAL_STORAGE_PATH=./.storage
# S3_ENDPOINT_URL=
# S3_REGION=
# S3_BUCKET=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# --- Presets: package | path | examples ---
# examples = in-repo demo set (default; no private library needed).
# path     = read a directory directly — point at a sibling checkout of the
#            private library for local dev (the library lives under src/library).
# package  = import an installed distribution (prod / private image; locally:
#            `make presets-dev` editable-installs the sibling, then set this).
PRESET_SOURCE=examples
# PRESET_LIBRARY_PATH=../presets/src/library
# PRESET_PACKAGE=photocore_presets

# --- Generation loop ---
MAX_ITERATIONS=8
